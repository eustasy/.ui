{
  "name": "@eustasy/ui",
  "version": "0.1.0",
  "description": "Open, accessible, customizable web components — vanilla HTML, CSS, minimal JS.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/eustasy/.ui.git"
  },
  "scripts": {
    "build": "lightningcss --minify --bundle --targets '>= 0.25%' assets/main.css -o dist/ui.min.css",
    "dev": "lightningcss --bundle --targets '>= 0.25%' assets/main.css -o dist/ui.min.css --watch",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "lightningcss-cli": "^1.29.0",
    "prettier": "^3.8.2"
  }
}
